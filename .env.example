# Copy to .env.local and fill in. Never commit .env.local.
# Source-of-truth for env var names: this file. Code reads exactly these names.

# ---- Supabase ----
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Apple Sign in with Apple ----
# Apple Developer Console > Identifiers, Keys
APPLE_TEAM_ID=
APPLE_SERVICE_ID=com.elisafazzari.node.signin
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_SIWA.p8
# For Edge Function deploys, the .p8 contents are passed as a single string secret:
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Apple Push Notification service (separate key from SiWA) ----
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_PATH=./secrets/AuthKey_APNS.p8
APNS_BUNDLE_ID=com.elisafazzari.node
# false = sandbox (TestFlight), true = production (App Store builds)
APNS_PRODUCTION=false

# ---- Cloudinary ----
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Must match the preset name created in Cloudinary > Upload > Add upload preset
CLOUDINARY_UPLOAD_PRESET_NODE=node-uploads-signed

# ---- UGC compliance / ops ----
# Inbox you actually monitor for abuse reports
CONTACT_EMAIL=
# Shared secret between iOS app and /api/push to prevent unauthenticated push abuse
PUSH_FANOUT_SECRET=
