# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apple Sign in with Apple (Apple Developer Console)
APPLE_TEAM_ID=
APPLE_SERVICE_ID=com.elisafazzari.node.signin
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/apple-signin-key.p8

# Apple Push Notification service (separate key from SiWA)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=./secrets/apns-auth-key.p8
APNS_BUNDLE_ID=com.elisafazzari.node
APNS_PRODUCTION=false

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET_NODE=node-uploads-signed

# UGC compliance
CONTACT_EMAIL=
PUSH_FANOUT_SECRET=
